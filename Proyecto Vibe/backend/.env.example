# MongoDB Atlas — reemplaza con tu cadena de conexión
MONGODB_URI=mongodb+srv://usuario:contraseña@cluster0.xxxxx.mongodb.net/admin-system?retryWrites=true&w=majority

# Puerto del servidor
PORT=3000

# Clerk (Quick Copy — cada clave en UNA sola línea)
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxx
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxx

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx
# En desarrollo puedes usar onboarding@resend.dev (solo envía a tu correo verificado)
RESEND_FROM=Proyecto Vibe <onboarding@resend.dev>

# Origen permitido del frontend
CORS_ORIGIN=http://localhost:5173

# Zona horaria (México)
TZ=America/Mexico_City
